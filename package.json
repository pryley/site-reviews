{
  "browserslist": [
    "defaults"
  ],
  "dependencies": {
    "autosize": "^6.0.1",
    "p-limit": "^7.1.1",
    "prismjs": "^1.30.0",
    "star-rating.js": "^4.3.1",
    "tippy.js": "^6.3.7",
    "tua-body-scroll-lock": "^1.5.1"
  },
  "devDependencies": {
    "@rollup/plugin-alias": "^5.1.1",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@wordpress/icons": "^10.31.0",
    "@wordpress/scripts": "^30.24.0",
    "babel-plugin-prismjs": "^2.1.0",
    "browser-sync": "^3.0.4",
    "gulp": "^5.0.0",
    "gulp-bump": "^3.2.0",
    "gulp-checktextdomain": "^2.3.0",
    "gulp-potomo": "^1.1.0",
    "gulp-pottopo": "^1.0.1",
    "gulp-sort": "^2.0.0",
    "gulp-wp-pot": "^2.5.0",
    "laravel-mix": "^6.0.49",
    "laravel-mix-bundle-analyzer": "^1.0.5",
    "postcss-calc": "^10.1.1",
    "postcss-custom-properties": "^14.0.3",
    "postcss-hexrgba": "^2.1.0",
    "postcss-import": "^16.0.0",
    "postcss-nested": "^7.0.2",
    "postcss-preset-env": "^10.1.6",
    "postcss-selector-namespace": "github:pryley/postcss-selector-namespace#master",
    "rollup": "^4.52.0",
    "rollup-plugin-filesize": "^10.0.0",
    "rollup-plugin-postcss": "^4.0.0"
  },
  "private": true,
  "scripts": {
    "blocks": "wp-scripts build --experimental-modules --config=+/blocks/webpack.config.js --source-path=+/blocks && wp-scripts build-blocks-manifest --input=assets/blocks --output=assets/blocks/blocks-manifest.php",
    "blocks:watch": "wp-scripts start --experimental-modules --config=+/blocks/webpack.config.js --source-path=+/blocks && wp-scripts build-blocks-manifest --input=assets/blocks --output=assets/blocks/blocks-manifest.php",
    "build": "gulp && mix --production",
    "check": "wp-scripts check-engines",
    "development": "mix",
    "i18n-pot": "wp i18n make-pot . languages/site-reviews.pot --slug=site-reviews --domain=site-reviews --exclude=+,node_modules,tests,vendor,vendors",
    "lang": "gulp",
    "watch": "mix watch",
    "watch-poll": "mix watch -- --watch-options-poll=1000",
    "hot": "mix watch --hot",
    "production": "mix --production"
  },
  "workspaces": [
    "+/packages/*"
  ]
}
