<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         bootstrap="tests/pest/bootstrap.php"
         cacheDirectory=".phpunit.cache"
         colors="true"
         displayDetailsOnTestsThatTriggerDeprecations="true"
         displayDetailsOnTestsThatTriggerErrors="true"
         displayDetailsOnTestsThatTriggerNotices="true"
         displayDetailsOnTestsThatTriggerWarnings="true"
         failOnNotice="true"
         failOnWarning="true"
         >
    <!-- THE THIRD-PARTY INTEGRATIONS, and only those. The twin of phpunit.xml:
         same bootstrap, same suites, the <source> list inverted.

         This number is REPORTED, NEVER GATED, and it is low on purpose. Most of
         what is measured here cannot execute without a plugin or theme that has to
         be bought (Divi, Bricks, Breakdance, WPBakery, Avada, Flatsome) or a
         multisite network (MultilingualPress). A signature-only stub gets us the
         hook registration, the version gate and the pure transformers, and stops
         at the first line that reads a value back from the third party.

         What moves this number is installing the real plugin (see .wp-env.json,
         which does exactly that for WooCommerce and Elementor), not writing more
         tests. Gating it would be gating your licence budget.

         Run it with: composer test:coverage:integrations -->
    <source>
        <include>
            <directory suffix=".php">plugin/Integrations/Avada</directory>
            <directory suffix=".php">plugin/Integrations/Breakdance</directory>
            <directory suffix=".php">plugin/Integrations/Bricks</directory>
            <directory suffix=".php">plugin/Integrations/BuddyBoss</directory>
            <directory suffix=".php">plugin/Integrations/Cache</directory>
            <directory suffix=".php">plugin/Integrations/CloudFlare</directory>
            <directory suffix=".php">plugin/Integrations/Divi</directory>
            <directory suffix=".php">plugin/Integrations/DuplicatePage</directory>
            <directory suffix=".php">plugin/Integrations/DuplicatePost</directory>
            <directory suffix=".php">plugin/Integrations/Elementor</directory>
            <directory suffix=".php">plugin/Integrations/Flatsome</directory>
            <directory suffix=".php">plugin/Integrations/Flywheel</directory>
            <directory suffix=".php">plugin/Integrations/GamiPress</directory>
            <directory suffix=".php">plugin/Integrations/JetWooBuilder</directory>
            <directory suffix=".php">plugin/Integrations/LPFW</directory>
            <directory suffix=".php">plugin/Integrations/MultilingualPress</directory>
            <directory suffix=".php">plugin/Integrations/MyCred</directory>
            <directory suffix=".php">plugin/Integrations/ProfilePress</directory>
            <directory suffix=".php">plugin/Integrations/RankMath</directory>
            <directory suffix=".php">plugin/Integrations/SASWP</directory>
            <directory suffix=".php">plugin/Integrations/SEOPress</directory>
            <directory suffix=".php">plugin/Integrations/SchemaPro</directory>
            <directory suffix=".php">plugin/Integrations/SureCart</directory>
            <directory suffix=".php">plugin/Integrations/UltimateMember</directory>
            <directory suffix=".php">plugin/Integrations/WLPR</directory>
            <directory suffix=".php">plugin/Integrations/WPBakery</directory>
            <directory suffix=".php">plugin/Integrations/WPLoyalty</directory>
            <directory suffix=".php">plugin/Integrations/WooCommerce</directory>
            <directory suffix=".php">plugin/Integrations/WooRewards</directory>
            <directory suffix=".php">plugin/Integrations/YoastSEO</directory>
            <file>plugin/Integrations/IntegrationHooks.php</file>
            <file>plugin/Integrations/IntegrationShortcode.php</file>
        </include>
    </source>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/pest/Unit</directory>
        </testsuite>
        <testsuite name="Integration">
            <directory>tests/pest/Integration</directory>
        </testsuite>
        <testsuite name="ThirdParty">
            <directory>tests/pest/ThirdParty</directory>
        </testsuite>
        <!-- Import runs LAST, and must go on running last.

             ProcessCsvFile and ImportManager define('WP_IMPORTING', true), a
             constant cannot be unset, and nineteen places in the plugin read it —
             it is what stops an import generating an avatar per review, emailing a
             verification per review, geolocating every IP and treating a
             spreadsheet row as a form submission. Correct during an import, wrong
             everywhere else. Declared last, there is nothing after it to poison.

             ThirdParty/CacheTest asserts WP_IMPORTING is NOT defined, so moving
             this fails loudly instead of quietly. -->
        <testsuite name="Import">
            <directory>tests/pest/Import</directory>
        </testsuite>
    </testsuites>
</phpunit>
